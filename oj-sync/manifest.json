{
  "manifest_version": 3,
  "name": "OJ Sync",
  "version": "1.0.1",
  "permissions": ["activeTab", "scripting", "storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "https://atcoder.jp/*",
    "http://atcoder.jp/*",
    "https://*.atcoder.jp/*",
    "http://*.atcoder.jp/*",
    "https://codeforces.com/*",
    "http://codeforces.com/*",
    "https://*.codeforces.com/*",
    "http://*.codeforces.com/*",
    "https://leetcode.com/*",
    "http://leetcode.com/*",
    "https://*.leetcode.com/*",
    "http://*.leetcode.com/*",
    "https://leetcode.cn/*",
    "http://leetcode.cn/*",
    "https://*.leetcode.cn/*",
    "http://*.leetcode.cn/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "OJ Sync 1.0.1 — samples -> CP Helper 1.0.1 (C++)"
  }
}
